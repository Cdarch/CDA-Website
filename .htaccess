# A.H.D Architects — Hostinger / Apache config

# Force UTF-8
AddDefaultCharset UTF-8

# Compress text-based responses
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml font/ttf font/otf application/xml
</IfModule>

# Cache assets aggressively (long cache + immutable). HTML stays fresh.
<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 7 days"
  ExpiresByType application/javascript    "access plus 7 days"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff2?|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Light security headers
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Custom 404 → fall back to homepage (hash routing handles deep links)
ErrorDocument 404 /index.html

# Hide source folders from public access
RedirectMatch 404 ^/_react-source(/|$)
